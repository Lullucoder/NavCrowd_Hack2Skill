# Backend server port used for local development.
PORT=8080

# Gemini API key for chatbot and AI summary features.
# Leave blank to use deterministic fallback replies.
GEMINI_API_KEY=your-gemini-api-key

# Google Maps Platform integration (optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Firebase runtime metadata for expanded Google services status reporting
FIREBASE_API_KEY=your-firebase-web-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
FIREBASE_VAPID_KEY=your-web-push-vapid-key
FIREBASE_FUNCTIONS_REGION=us-central1
