{
  "name": "physical-event-experience",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "build": "tsc && vite build",
    "test": "npm run test:backend",
    "test:backend": "npm --prefix backend run test",
    "verify": "npm run test:backend && npm run build",
    "preview": "vite preview",
    "start:backend": "npm --prefix backend start",
    "deploy:frontend": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-frontend.ps1 -FirebaseProjectId your-firebase-project-id",
    "deploy:backend": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy-backend.ps1 -ProjectId your-gcp-project-id"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.4"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  }
}
