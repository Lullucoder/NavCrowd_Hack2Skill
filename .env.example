# Frontend API base URL for local development.
# Keep this as localhost when running backend locally.
# For Firebase Hosting + Cloud Run rewrite in production, this can be left empty in the runtime env.
VITE_API_BASE_URL=

# Firebase Web App configuration (Google Services expansion)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Missing from provided Firebase snippet:
# - Measurement ID from Firebase Console -> Project settings -> General -> Your apps
# - Web Push VAPID key from Firebase Console -> Cloud Messaging
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_VAPID_KEY=
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
